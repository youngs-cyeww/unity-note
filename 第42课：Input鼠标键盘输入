#region 知识点一鼠标在屏幕位置

//屏幕坐标的原点是在屏幕的左下角 往右是x轴正方向往上时轴正方向
//返回值时Vector3 但是只有 xy有值一直是是因为屏幕本来就是2D的不存在Z轴
print(Input.mousePosition);

#endregion

#region 知识点二检测鼠标输入

//鼠标按下一瞬间进入
//左键 1右键 2中键
//只要按下的这一瞬间进入一次
if(Input.GetMouseButtonDown(8))
{
print(“鼠标左键按下了");
}

//鼠标抬起一瞬间进入
if(Input.GetMouseButtonUp(0))
{
print("鼠标左键抬起了”);
}

//鼠标长按按下抬起都会进入
//就是当按住按键不放时会一直进入这个判断
if(Input.GetMouseButton(1))
{
print("右键按下");
}

//中键滚动
//返回值的y-1往下滚 没有滚 1往上滚
//它的返回值是Vector的值 我们鼠标中键滚动会改变其中的值
print(Input.mouseScrollDelta);

#endregion

